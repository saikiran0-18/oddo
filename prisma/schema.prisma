generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     String // Fleet Manager, Driver, Safety Officer, Financial Analyst
}

model Vehicle {
  id                 String  @id @default(uuid())
  registrationNumber String  @unique
  name               String
  type               String
  maxLoadCapacity    Float
  odometer           Float   @default(0)
  acquisitionCost    Float
  status             String  @default("Available") // Available, On Trip, In Shop, Retired

  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  documents          VehicleDocument[]
}

model Driver {
  id                String  @id @default(uuid())
  name              String
  licenseNumber     String  @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Float   @default(100)
  status            String  @default("Available") // Available, On Trip, Off Duty, Suspended

  trips             Trip[]
}

model Trip {
  id              String  @id @default(uuid())
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance  Float
  actualDistance   Float?  // Set on completion — real distance driven
  status           String  @default("Draft") // Draft, Dispatched, Completed, Cancelled

  vehicleId       String
  vehicle         Vehicle @relation(fields: [vehicleId], references: [id])

  driverId        String
  driver          Driver  @relation(fields: [driverId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MaintenanceLog {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  description String
  cost        Float
  status      String   @default("Active") // Active, Closed

  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
}

model FuelLog {
  id        String   @id @default(uuid())
  date      DateTime @default(now())
  liters    Float
  cost      Float

  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  description String
  amount      Float
  category    String   // Tolls, General, etc.
}

model VehicleDocument {
  id        String   @id @default(uuid())
  name      String
  url       String
  uploadedAt DateTime @default(now())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
}
